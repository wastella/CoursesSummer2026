// File name: projects/1/And.hdl
/**
 * And gate:
 * if (a and b) out = 1, else out = 0 
 */
CHIP And {
    IN in1, in2;
    OUT out;
    
    PARTS:
    Nand(a=in1, b=in2, out=q);
    Not(in=q, out=out);
}