// File name: projects/1/Xor.hdl
/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    Or(a=a, b=b, out=in1);
    And(a=a, b=b, out=in2);
    Not(in=in2, out=in3);
    And(a=in1, b=in3, out=out);
}